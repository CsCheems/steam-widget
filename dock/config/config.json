{
  "app": {
    "title": "Achievement Tracker",
    "subtitle": "Show your achievement progress to your friends.",
    "brandLabel": "Steam Achievement Tracker"
  },
  "base": {
    "baseUrlLabel": "Widget base URL",
    "baseUrlPlaceholder": "https://cscheems.github.io/steam-widget/",
    "defaultBaseUrl": "https://cscheems.github.io/steam-widget/"
  },
  "sections": [
    {
      "id": "widgetBehaviour",
      "title": "Game Info",
      "description": "Shows Game Name and List of Locked Achievements",
      "fields": [
        {
          "type": "text",
          "id": "gameName",
          "label": "Game",
          "param": "gameName",
          "default": "",
          "placeholder": ""
        },
        {
          "type": "switch",
          "id": "autoColor",
          "label": "Auto Color",
          "param": "autoColor",
          "default": true
        },
        {
          "type": "color",
          "id": "widgetColor",
          "label": "Widget Color",
          "param": "widgetColor",
          "default": "#ffffff",
          "variant": "swatch",
          "showWhen": { "field": "autoColor", "is": false }
        },
        {
          "type": "button",
          "id": "saveBtn",
          "param": "",
          "default": ""
        },
        {
            "type": "select",
            "id": "lockedAchievement",
            "label": "Achievement to Track",
            "param": "lockedAchievement",
            "default": 0
        }, 
        {
          "type": "switch",
          "id": "trackedMode",
          "label": "Track achievement",
          "param": "trackMode",
          "default": false
        }
      ]
    }
  ]
}
